{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Candybar",
  "version": "0.1.0",
  "identifier": "sh.delo.candybar",
  "build": {
    "beforeDevCommand": "npm run vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Candybar",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "alwaysOnTop": false
      }
    ]
  }
}
